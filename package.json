{
  "name": "lib-maestro-dmx",
  "version": "1.1.0",
  "description": "Node.js library for controlling MaestroDMX via OSC and reading show state via HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "live-test": "tsx test/live-test.ts",
    "live-test:brightness-latency": "tsx test/brightness-latency-live-test.ts",
    "live-test:notifications": "tsx test/notifications-live-test.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test && npm run typecheck",
    "sandbox": "tsx test/sandbox-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "maestrodmx",
    "osc",
    "lighting",
    "dmx",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/matterlobby/lib-maestrodmx-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/matterlobby/lib-maestrodmx-bridge/issues"
  },
  "homepage": "https://github.com/matterlobby/lib-maestrodmx-bridge#readme"
}
